#!/usr/bin/env node

const path = require('path');
const fs = require('fs');
const { spawnSync } = require('child_process');

if (process.platform !== 'darwin') {
  console.error('macvision is only available on macOS.');
  process.exit(1);
}

const binary = path.join(__dirname, 'macvision-binary');
if (!fs.existsSync(binary)) {
  console.error('macvision binary not found. Try reinstalling the package.');
  process.exit(1);
}

const result = spawnSync(binary, process.argv.slice(2), { stdio: 'inherit' });
process.exit(result.status ?? 0);
